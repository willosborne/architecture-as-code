# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# docker compose automatically loads .env from the current directory.

# Image to run. Defaults to the latest self-contained read-only-native build.
# To pin a version (e.g. to roll back), point this at an immutable sha tag
# published by .github/workflows/docker-publish-calm-hub-readonly-native.yml:
#   CALM_HUB_IMAGE=finos/calm-hub:sha-1a2b3c4-read-only-native
# A pinned sha tag never changes upstream, so Watchtower has nothing new to
# pull and effectively stops auto-updating until you set this back to
# latest-read-only-native.
CALM_HUB_IMAGE=finos/calm-hub:latest-read-only-native

# How often Watchtower polls Docker Hub for a newer image, in seconds.
WATCHTOWER_POLL_INTERVAL=120
